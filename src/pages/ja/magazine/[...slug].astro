---
// ja/magazine/[...slug].astro - 日本語版 記事詳細ページ
// ja/ サブフォルダの記事をレンダリングして表示

import Article from '../../../layouts/Article.astro';
import RelatedProducts from '../../../components/RelatedProducts.astro';
import { getCollection, render } from 'astro:content';
import bootsData from '../../../data/boots.json';

// 静的パス生成（ja/ プレフィックスの記事のみ）
export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles
    .filter(a => a.id.startsWith('ja/'))
    .map((article) => ({
      params: { slug: article.id.replace('ja/', '') },
      props: { article },
    }));
}

// 記事データを取得
const { article } = Astro.props;

// MarkdownをHTMLにレンダリング
const { Content } = await render(article);

// frontmatter の relatedBoots IDリストからブーツデータを取得
const relatedIds = article.data.relatedBoots || [];
const matchedBoots = relatedIds.map((id: string) =>
  bootsData.find((b: any) => b.id === id)
).filter(Boolean);
---

<Article
  title={article.data.title}
  description={article.data.description}
  category={article.data.category}
  publishedAt={article.data.publishedAt}
  updatedAt={article.data.updatedAt}
  tags={article.data.tags}
>
  <Content />
  <RelatedProducts boots={matchedBoots} />
</Article>
