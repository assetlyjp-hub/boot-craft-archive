---
// ja/index.astro - 日本語版トップページ
// 英語版と同じ構造で、テキストのみ日本語に

import Base from '../../layouts/Base.astro';
import bootsData from '../../data/boots.json';
---

<Base
  title="Boot Craft Archive"
  description="世界の名門ブーツメーカーのデータベース。サービスブーツ、オックスフォード、ダービーなど、クラフテッドフットウェアの全てがここに。"
  jaPath="/ja/"
>
  <!-- ヒーローセクション -->
  <section class="hero">
    <h1 class="hero__title">Boot Craft <span>Archive</span></h1>
    <p class="hero__subtitle" style="font-family: var(--font-ja);">
      クラフテッドフットウェアの全てを、ここに。
    </p>
  </section>

  <!-- メインコンテンツ -->
  <div class="container">
    <!-- 簡易説明 -->
    <div style="text-align: center; padding: var(--space-md) 0 var(--space-lg); border-bottom: 1px solid var(--color-border); margin-bottom: var(--space-lg);">
      <p style="font-family: var(--font-ja); max-width: 600px; margin: 0 auto;">
        世界の名門ブーツメーカーが手掛けるフットウェアのデータベース。
        レッドウィング、オールデン、ヴァイバーグ、トリッカーズなど、
        各ブランドの名作を網羅的に紹介します。
      </p>
    </div>

    <!-- ブーツグリッド -->
    <div class="item-grid">
      {bootsData.map((boot) => (
        <a href={`/boots/${boot.id}/`} class="item-card">
          <img src={boot.image} alt={boot.nameJa} class="item-card__image" loading="lazy" />
          <div class="item-card__body">
            <p class="item-card__type">{boot.category.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</p>
            <h3 class="item-card__name" style="font-family: var(--font-ja);">{boot.nameJa}</h3>
            <p class="item-card__brand">{boot.brand.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase())}</p>
            <div class="item-card__meta">
              <span class="item-card__tag">{boot.madeIn}</span>
              <span class="item-card__tag">{boot.construction.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
              <span class="item-card__price">${boot.price}</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- 英語版への誘導 -->
    <div style="text-align: center; padding: var(--space-xl) 0;">
      <a href="/" class="btn">View Full English Site</a>
    </div>
  </div>
</Base>
